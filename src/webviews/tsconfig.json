{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["dom", "dom.iterable", "esnext"],
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "moduleResolution": "bundler",
        "skipLibCheck": true
    },
    "include": [
        "tree-table/src",
        "trace-configuration/src"
    ]
}
