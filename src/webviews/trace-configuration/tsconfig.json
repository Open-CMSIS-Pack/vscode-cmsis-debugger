{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["dom", "dom.iterable", "esnext"],
        "strict": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "moduleResolution": "bundler",
        "skipLibCheck": true
    },
    "include": ["src"]
}
