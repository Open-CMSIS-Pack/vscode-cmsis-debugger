{
  "name": "vscode-cmsis-debugger",
  "displayName": "Arm CMSIS Debugger",
  "description": "Run and debug embedded and Edge AI projects on Arm Cortex-M single or multi core devices. Connects via pyOCD to CMSIS-DAP or other GDB servers.",
  "version": "1.7.0",
  "preview": false,
  "publisher": "Arm",
  "author": "Jens Reinecke <jens.reinecke@arm.com>",
  "license": "SEE LICENSE IN LICENSE",
  "main": "dist/main.js",
  "repository": "https://github.com/Open-CMSIS-Pack/vscode-cmsis-debugger",
  "qna": "https://github.com/Open-CMSIS-Pack/vscode-cmsis-debugger/issues",
  "bugs": {
    "url": "https://github.com/Open-CMSIS-Pack/vscode-cmsis-debugger/issues"
  },
  "icon": "media/arm.png",
  "galleryBanner": {
    "color": "#333E48",
    "theme": "dark"
  },
  "engines": {
    "node": "^22.22.0",
    "npm": "^10.0.0",
    "vscode": "^1.108.1"
  },
  "categories": [
    "Debuggers"
  ],
  "keywords": [
    "arm",
    "microcontroller",
    "embedded",
    "CMSIS"
  ],
  "extensionPack": [
    "eclipse-cdt.cdt-gdb-vscode",
    "eclipse-cdt.memory-inspector",
    "eclipse-cdt.peripheral-inspector",
    "ms-vscode.vscode-serial-monitor"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cmsis-debugger",
          "title": "Trace and Live View",
          "icon": "media/trace-and-live-dark.svg"
        }
      ]
    },
    "views": {
      "cmsis-debugger": [
        {
          "id": "cmsis-debugger.liveWatch",
          "name": "Live Watch",
          "icon": "media/trace-and-live-light.svg"
        },
        {
          "id": "cmsis-debugger.componentViewer",
          "type": "webview",
          "name": "Component Viewer",
          "icon": "media/trace-and-live-light.svg"
        },
        {
          "id": "cmsis-debugger.corePeripherals",
          "type": "webview",
          "name": "Core Peripherals",
          "icon": "media/trace-and-live-light.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-cmsis-debugger.resetDynamicViewState",
        "title": "Reset All Dynamic View States",
        "category": "CMSIS Debugger"
      },
      {
        "command": "vscode-cmsis-debugger.openDisassemblyView",
        "title": "Open Disassembly View",
        "category": "Run and Debug",
        "when": "inDebugMode"
      },
      {
        "title": "CPU Time",
        "shortTitle": "CPU Time",
        "command": "vscode-cmsis-debugger.showCpuTimeHistory",
        "category": "Run and Debug",
        "when": "inDebugMode"
      },
      {
        "title": "Reset CPU Time",
        "shortTitle": "CPU Time",
        "command": "vscode-cmsis-debugger.resetCpuTimeHistory",
        "category": "Run and Debug",
        "when": "inDebugMode"
      },
      {
        "title": "Enable CPU Time",
        "command": "vscode-cmsis-debugger.enableCpuTimer",
        "category": "Run and Debug",
        "when": "inDebugMode",
        "enablement": "!vscode-cmsis-debugger.cpuTimerEnabled"
      },
      {
        "title": "Disable CPU Time",
        "command": "vscode-cmsis-debugger.disableCpuTimer",
        "category": "Run and Debug",
        "when": "inDebugMode",
        "enablement": "vscode-cmsis-debugger.cpuTimerEnabled"
      },
      {
        "command": "vscode-cmsis-debugger.liveWatch.add",
        "title": "Add Expression",
        "icon": "$(add)",
        "category": "Live Watch"
      },
      {
        "command": "vscode-cmsis-debugger.liveWatch.deleteAll",
        "title": "Delete All Expressions",
        "icon": "$(close-all)",
        "category": "Live Watch"
      },
      {
        "command": "vscode-cmsis-debugger.liveWatch.delete",
        "title": "Delete Expression",
        "icon": "$(close)",
        "category": "Live Watch"
      },
      {
        "command": "vscode-cmsis-debugger.liveWatch.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Live Watch"
      },
      {
        "command": "vscode-cmsis-debugger.liveWatch.modify",
        "title": "Modify Expression",
        "icon": "$(pencil)",
        "category": "Live Watch"
      },
      {
        "command": "vscode-cmsis-debugger.liveWatch.copy",
        "title": "Copy Expression",
        "category": "Live Watch"
      },
      {
        "command": "vscode-cmsis-debugger.liveWatch.addToLiveWatchFromTextEditor",
        "title": "Add to Live Watch",
        "category": "Live Watch"
      },
      {
        "command": "vscode-cmsis-debugger.liveWatch.addToLiveWatchFromWatchWindow",
        "title": "Add to Live Watch",
        "category": "Live Watch"
      },
      {
        "command": "vscode-cmsis-debugger.liveWatch.addToLiveWatchFromVariablesView",
        "title": "Add to Live Watch",
        "category": "Live Watch"
      },
      {
        "command": "vscode-cmsis-debugger.liveWatch.showInMemoryInspector",
        "title": "Show in Memory Inspector",
        "category": "Live Watch"
      },
      {
        "command": "vscode-cmsis-debugger.liveWatch.enablePeriodicUpdate",
        "title": "Enable Periodic Update",
        "icon": "$(sync)",
        "category": "Live Watch"
      },
      {
        "command": "vscode-cmsis-debugger.liveWatch.disablePeriodicUpdate",
        "title": "Disable Periodic Update",
        "icon": "$(sync-ignored)",
        "category": "Live Watch"
      },
      {
        "command": "vscode-cmsis-debugger.liveWatch.setValue",
        "title": "Set Value",
        "category": "Live Watch"
      },
      {
        "command": "vscode-cmsis-debugger.liveWatch.resetViewState",
        "title": "Reset View State",
        "category": "Live Watch"
      },
      {
        "command": "vscode-cmsis-debugger.componentViewer.lockComponent",
        "title": "Lock Component Display",
        "icon": "$(lock)",
        "category": "Component Viewer"
      },
      {
        "command": "vscode-cmsis-debugger.componentViewer.unlockComponent",
        "title": "Unlock Component Display",
        "icon": "$(unlock)",
        "category": "Component Viewer"
      },
      {
        "command": "vscode-cmsis-debugger.componentViewer.copy",
        "title": "Copy",
        "category": "Component Viewer"
      },
      {
        "command": "vscode-cmsis-debugger.componentViewer.copyRow",
        "title": "Copy Row",
        "category": "Component Viewer"
      },
      {
        "command": "vscode-cmsis-debugger.componentViewer.enablePeriodicUpdate",
        "title": "Enable Periodic Update",
        "icon": "$(sync)",
        "category": "Component Viewer"
      },
      {
        "command": "vscode-cmsis-debugger.componentViewer.disablePeriodicUpdate",
        "title": "Disable Periodic Update",
        "icon": "$(sync-ignored)",
        "category": "Component Viewer"
      },
      {
        "command": "vscode-cmsis-debugger.componentViewer.expandAll",
        "title": "Expand All",
        "icon": "$(expand-all)",
        "category": "Component Viewer"
      },
      {
        "command": "vscode-cmsis-debugger.componentViewer.collapseAll",
        "title": "Collapse All",
        "icon": "$(collapse-all)",
        "category": "Component Viewer"
      },
      {
        "command": "vscode-cmsis-debugger.componentViewer.filterTree",
        "title": "Filter Tree",
        "icon": "$(filter)",
        "category": "Component Viewer"
      },
      {
        "command": "vscode-cmsis-debugger.componentViewer.clearFilter",
        "title": "Clear Filter",
        "icon": "$(clear-all)",
        "category": "Component Viewer"
      },
      {
        "command": "vscode-cmsis-debugger.componentViewer.resetViewState",
        "title": "Reset View State",
        "category": "Component Viewer"
      },
      {
        "command": "vscode-cmsis-debugger.corePeripherals.lockComponent",
        "title": "Lock Peripheral Display",
        "icon": "$(lock)",
        "category": "Core Peripherals"
      },
      {
        "command": "vscode-cmsis-debugger.corePeripherals.unlockComponent",
        "title": "Unlock Peripheral Display",
        "icon": "$(unlock)",
        "category": "Core Peripherals"
      },
      {
        "command": "vscode-cmsis-debugger.corePeripherals.copy",
        "title": "Copy",
        "category": "Core Peripherals"
      },
      {
        "command": "vscode-cmsis-debugger.corePeripherals.copyRow",
        "title": "Copy Row",
        "category": "Core Peripherals"
      },
      {
        "command": "vscode-cmsis-debugger.corePeripherals.enablePeriodicUpdate",
        "title": "Enable Periodic Update",
        "icon": "$(sync)",
        "category": "Core Peripherals"
      },
      {
        "command": "vscode-cmsis-debugger.corePeripherals.disablePeriodicUpdate",
        "title": "Disable Periodic Update",
        "icon": "$(sync-ignored)",
        "category": "Core Peripherals"
      },
      {
        "command": "vscode-cmsis-debugger.corePeripherals.expandAll",
        "title": "Expand All",
        "icon": "$(expand-all)",
        "category": "Core Peripherals"
      },
      {
        "command": "vscode-cmsis-debugger.corePeripherals.collapseAll",
        "title": "Collapse All",
        "icon": "$(collapse-all)",
        "category": "Core Peripherals"
      },
      {
        "command": "vscode-cmsis-debugger.corePeripherals.filterTree",
        "title": "Filter Tree",
        "icon": "$(filter)",
        "category": "Core Peripherals"
      },
      {
        "command": "vscode-cmsis-debugger.corePeripherals.clearFilter",
        "title": "Clear Filter",
        "icon": "$(clear-all)",
        "category": "Core Peripherals"
      },
      {
        "command": "vscode-cmsis-debugger.corePeripherals.resetViewState",
        "title": "Reset View State",
        "category": "Core Peripherals"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vscode-cmsis-debugger.liveWatch.addToLiveWatchFromTextEditor",
          "when": "editorTextFocus",
          "group": "z_commands"
        }
      ],
      "editor/lineNumber/context": [
        {
          "command": "vscode-cmsis-debugger.openDisassemblyView",
          "when": "inDebugMode",
          "group": "z_commands"
        }
      ],
      "debug/variables/context": [
        {
          "command": "vscode-cmsis-debugger.liveWatch.addToLiveWatchFromVariablesView",
          "when": "inDebugMode",
          "group": "z_commands"
        }
      ],
      "debug/watch/context": [
        {
          "command": "vscode-cmsis-debugger.liveWatch.addToLiveWatchFromWatchWindow",
          "when": "inDebugMode",
          "group": "z_commands"
        }
      ],
      "commandPalette": [
        {
          "command": "vscode-cmsis-debugger.resetDynamicViewState",
          "when": "true"
        },
        {
          "command": "vscode-cmsis-debugger.openDisassemblyView",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.showCpuTimeHistory",
          "when": "inDebugMode"
        },
        {
          "command": "vscode-cmsis-debugger.resetCpuTimeHistory",
          "when": "inDebugMode"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.add",
          "when": "true"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.deleteAll",
          "when": "true"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.refresh",
          "when": "inDebugMode"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.modify",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.delete",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.copy",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.addToLiveWatchFromTextEditor",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.addToLiveWatchFromWatchWindow",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.addToLiveWatchFromVariablesView",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.showInMemoryInspector",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.enablePeriodicUpdate",
          "when": "inDebugMode && liveWatch.canAccessWhileRunning && !liveWatch.periodicUpdateEnabled"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.disablePeriodicUpdate",
          "when": "inDebugMode && liveWatch.canAccessWhileRunning && liveWatch.periodicUpdateEnabled"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.setValue",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.resetViewState",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.lockComponent",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.unlockComponent",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.copy",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.copyRow",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.enablePeriodicUpdate",
          "when": "inDebugMode && componentViewer.canAccessWhileRunning && !componentViewer.periodicUpdateEnabled"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.disablePeriodicUpdate",
          "when": "inDebugMode && componentViewer.canAccessWhileRunning && componentViewer.periodicUpdateEnabled"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.expandAll",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.collapseAll",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.filterTree",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.clearFilter",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.resetViewState",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.lockComponent",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.unlockComponent",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.copy",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.copyRow",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.enablePeriodicUpdate",
          "when": "inDebugMode && corePeripherals.canAccessWhileRunning && !corePeripherals.periodicUpdateEnabled"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.disablePeriodicUpdate",
          "when": "inDebugMode && corePeripherals.canAccessWhileRunning && corePeripherals.periodicUpdateEnabled"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.expandAll",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.collapseAll",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.filterTree",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.clearFilter",
          "when": "false"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.resetViewState",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "vscode-cmsis-debugger.liveWatch.add",
          "when": "view == cmsis-debugger.liveWatch"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.deleteAll",
          "when": "view == cmsis-debugger.liveWatch"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.refresh",
          "when": "inDebugMode && view == cmsis-debugger.liveWatch"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.add",
          "when": "view == cmsis-debugger.liveWatch",
          "group": "navigation@1"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.deleteAll",
          "when": "view == cmsis-debugger.liveWatch",
          "group": "navigation@4"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.refresh",
          "when": "inDebugMode && view == cmsis-debugger.liveWatch",
          "group": "navigation@2"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.disablePeriodicUpdate",
          "when": "inDebugMode && view == cmsis-debugger.liveWatch && liveWatch.canAccessWhileRunning && liveWatch.periodicUpdateEnabled",
          "group": "navigation@3"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.enablePeriodicUpdate",
          "when": "inDebugMode && view == cmsis-debugger.liveWatch && liveWatch.canAccessWhileRunning && !liveWatch.periodicUpdateEnabled",
          "group": "navigation@3"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.expandAll",
          "when": "inDebugMode && view == cmsis-debugger.componentViewer",
          "group": "navigation@3"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.collapseAll",
          "when": "inDebugMode && view == cmsis-debugger.componentViewer",
          "group": "navigation@4"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.expandAll",
          "when": "inDebugMode && view == cmsis-debugger.corePeripherals",
          "group": "navigation@3"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.collapseAll",
          "when": "inDebugMode && view == cmsis-debugger.corePeripherals",
          "group": "navigation@4"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.filterTree",
          "when": "inDebugMode && view == cmsis-debugger.componentViewer",
          "group": "navigation@1"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.clearFilter",
          "when": "view == cmsis-debugger.componentViewer && componentViewer.filterActive",
          "group": "navigation@2"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.filterTree",
          "when": "inDebugMode && view == cmsis-debugger.corePeripherals",
          "group": "navigation@1"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.clearFilter",
          "when": "view == cmsis-debugger.corePeripherals && corePeripherals.filterActive",
          "group": "navigation@2"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.disablePeriodicUpdate",
          "when": "inDebugMode && view == cmsis-debugger.componentViewer && componentViewer.canAccessWhileRunning && componentViewer.periodicUpdateEnabled",
          "group": "navigation@3"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.enablePeriodicUpdate",
          "when": "inDebugMode && view == cmsis-debugger.componentViewer && componentViewer.canAccessWhileRunning && !componentViewer.periodicUpdateEnabled",
          "group": "navigation@3"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.disablePeriodicUpdate",
          "when": "inDebugMode && view == cmsis-debugger.corePeripherals && corePeripherals.canAccessWhileRunning && corePeripherals.periodicUpdateEnabled",
          "group": "navigation@3"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.enablePeriodicUpdate",
          "when": "inDebugMode && view == cmsis-debugger.corePeripherals && corePeripherals.canAccessWhileRunning && !corePeripherals.periodicUpdateEnabled",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "vscode-cmsis-debugger.liveWatch.modify",
          "when": "view == cmsis-debugger.liveWatch && viewItem == parentExpression",
          "group": "inline@1"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.delete",
          "when": "view == cmsis-debugger.liveWatch && viewItem == parentExpression",
          "group": "inline@2"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.add",
          "when": "view == cmsis-debugger.liveWatch",
          "group": "contextMenuG1@1"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.modify",
          "when": "view == cmsis-debugger.liveWatch && viewItem == parentExpression",
          "group": "contextMenuG1@2"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.copy",
          "when": "view == cmsis-debugger.liveWatch",
          "group": "contextMenuG1@3"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.delete",
          "when": "view == cmsis-debugger.liveWatch && viewItem == parentExpression",
          "group": "contextMenuG1@4"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.setValue",
          "when": "inDebugMode && view == cmsis-debugger.liveWatch && vscode-cmsis-debugger.setExpressionSupported",
          "group": "contextMenuG1@5"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.refresh",
          "when": "view == cmsis-debugger.liveWatch",
          "group": "contextMenuG2@2"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.enablePeriodicUpdate",
          "when": "inDebugMode && view == cmsis-debugger.liveWatch && liveWatch.canAccessWhileRunning && !liveWatch.periodicUpdateEnabled",
          "group": "contextMenuG2@3"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.disablePeriodicUpdate",
          "when": "inDebugMode && view == cmsis-debugger.liveWatch && liveWatch.canAccessWhileRunning && liveWatch.periodicUpdateEnabled",
          "group": "contextMenuG2@3"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.showInMemoryInspector",
          "when": "view == cmsis-debugger.liveWatch",
          "group": "contextMenuG3@1"
        },
        {
          "command": "cdt.debug.setOutputRadixToDecimal",
          "when": "inDebugMode && (view == cmsis-debugger.liveWatch) && cdt.debug.outputRadix && cdt.debug.outputRadix != 'decimal' && (debugType == 'gdb' || debugType == 'gdbtarget')",
          "group": "contextMenuG4@1"
        },
        {
          "command": "cdt.debug.setOutputRadixToHex",
          "when": "inDebugMode && (view == cmsis-debugger.liveWatch) && cdt.debug.outputRadix && cdt.debug.outputRadix != 'hexadecimal' && (debugType == 'gdb' || debugType == 'gdbtarget')",
          "group": "contextMenuG4@2"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.deleteAll",
          "when": "view == cmsis-debugger.liveWatch",
          "group": "contextMenuG5@1"
        },
        {
          "command": "vscode-cmsis-debugger.liveWatch.resetViewState",
          "when": "inDebugMode && view == cmsis-debugger.liveWatch",
          "group": "contextMenuG5@2"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.lockComponent",
          "when": "view == cmsis-debugger.componentViewer && viewItem == parentInstance",
          "group": "inline@1"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.unlockComponent",
          "when": "view == cmsis-debugger.componentViewer && viewItem == locked.parentInstance",
          "group": "inline@2"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.lockComponent",
          "when": "view == cmsis-debugger.corePeripherals && viewItem == parentInstance",
          "group": "inline@1"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.unlockComponent",
          "when": "view == cmsis-debugger.corePeripherals && viewItem == locked.parentInstance",
          "group": "inline@2"
        }
      ],
      "webview/context": [
        {
          "command": "vscode-cmsis-debugger.componentViewer.copy",
          "when": "webviewId == 'cmsis-debugger.componentViewer' && hasCopyText",
          "group": "contextMenuG1@1"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.copyRow",
          "when": "webviewId == 'cmsis-debugger.componentViewer' && hasRowValue",
          "group": "contextMenuG1@2"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.enablePeriodicUpdate",
          "when": "inDebugMode && webviewId == 'cmsis-debugger.componentViewer' && componentViewer.canAccessWhileRunning && !componentViewer.periodicUpdateEnabled",
          "group": "contextMenuG2@1"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.disablePeriodicUpdate",
          "when": "inDebugMode && webviewId == 'cmsis-debugger.componentViewer' && componentViewer.canAccessWhileRunning && componentViewer.periodicUpdateEnabled",
          "group": "contextMenuG2@1"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.lockComponent",
          "when": "webviewId == 'cmsis-debugger.componentViewer' && isRowLockable && !isRowLocked",
          "group": "contextMenuG2@2"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.unlockComponent",
          "when": "webviewId == 'cmsis-debugger.componentViewer' && isRowLockable && isRowLocked",
          "group": "contextMenuG2@2"
        },
        {
          "command": "vscode-cmsis-debugger.componentViewer.resetViewState",
          "when": "inDebugMode && webviewId == 'cmsis-debugger.componentViewer'",
          "group": "contextMenuG3@1"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.copy",
          "when": "webviewId == 'cmsis-debugger.corePeripherals' && hasCopyText",
          "group": "contextMenuG1@1"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.copyRow",
          "when": "webviewId == 'cmsis-debugger.corePeripherals' && hasRowValue",
          "group": "contextMenuG1@2"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.enablePeriodicUpdate",
          "when": "inDebugMode && webviewId == 'cmsis-debugger.corePeripherals' && corePeripherals.canAccessWhileRunning && !corePeripherals.periodicUpdateEnabled",
          "group": "contextMenuG2@1"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.disablePeriodicUpdate",
          "when": "inDebugMode && webviewId == 'cmsis-debugger.corePeripherals' && corePeripherals.canAccessWhileRunning && corePeripherals.periodicUpdateEnabled",
          "group": "contextMenuG2@1"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.lockComponent",
          "when": "webviewId == 'cmsis-debugger.corePeripherals' && isRowLockable && !isRowLocked",
          "group": "contextMenuG2@2"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.unlockComponent",
          "when": "webviewId == 'cmsis-debugger.corePeripherals' && isRowLockable && isRowLocked",
          "group": "contextMenuG2@2"
        },
        {
          "command": "vscode-cmsis-debugger.corePeripherals.resetViewState",
          "when": "inDebugMode && webviewId == 'cmsis-debugger.corePeripherals'",
          "group": "contextMenuG3@1"
        }
      ]
    },
    "debuggers": [
      {
        "type": "*",
        "configurationAttributes": {
          "launch": {
            "properties": {
              "cmsis": {
                "type": "object",
                "description": "Configures CMSIS Debugger settings.",
                "additionalProperties": false,
                "properties": {
                  "cbuildRunFile": {
                    "type": "string",
                    "description": "Path to *.cbuild-run.yml debug configuration file generated with CMSIS-Toolbox."
                  }
                }
              }
            }
          },
          "attach": {
            "properties": {
              "cmsis": {
                "type": "object",
                "description": "Configures CMSIS Debugger settings.",
                "additionalProperties": false,
                "properties": {
                  "cbuildRunFile": {
                    "type": "string",
                    "description": "Path to *.cbuild-run.yml debug configuration file generated with CMSIS-Toolbox."
                  }
                }
              }
            }
          }
        }
      }
    ],
    "configuration": {
      "title": "CMSIS Debugger",
      "properties": {
        "vscode-cmsis-debugger.viewState": {
          "type": "object",
          "markdownDescription": "Persisted dynamic view state per debug configuration.",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "componentViewer": {
                "type": "object",
                "markdownDescription": "Persisted dynamic view state for the Component Viewer.",
                "additionalProperties": false,
                "properties": {
                  "periodicUpdateEnabled": { "type": "boolean" },
                  "filterPattern": { "type": "string" }
                }
              },
              "corePeripherals": {
                "type": "object",
                "markdownDescription": "Persisted dynamic view state for the Core Peripherals view.",
                "additionalProperties": false,
                "properties": {
                  "periodicUpdateEnabled": { "type": "boolean" },
                  "filterPattern": { "type": "string" }
                }
              },
              "cpuStatesEnabled": {
                "type": "boolean",
                "markdownDescription": "Persisted CPU time enable/disable state."
              },
              "liveWatchPeriodicUpdateEnabled": {
                "type": "boolean",
                "markdownDescription": "Persisted Live Watch periodic update enable/disable state."
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "prepare": "npm run build",
    "download-tools": "tsx scripts/download-tools.ts pyocd gdb",
    "download-tools:nightly": "tsx scripts/download-tools.ts pyocdNightly gdb",
    "validate-tools": "tsx scripts/validate-tools.ts",
    "clean": "git clean -f -x ./node_modules ./dist ./coverage ./tools",
    "build": "webpack --mode production && npm run lint",
    "build:no-lint": "webpack --mode production",
    "watch": "webpack -w",
    "lint": "eslint .",
    "test": "jest --reporters=default --reporters=./node_modules/jest-html-reporter",
    "all": "npm install && npm run download-tools && npm run test",
    "package": "node ./scripts/vsce-release.js",
    "tpip:report": "tsx scripts/tpip-reporter --header docs/tpip-header.md docs/third-party-licenses.json TPIP.md",
    "lint:md": "markdownlint **/*.md -c ./.github/markdownlint.jsonc -i ./node_modules -i ./dist -i ./coverage -i ./tools",
    "check:links": "tsx scripts/check-links.ts -i ./node_modules/** -i ./.github/** -c ./.github/markdown-link-check.jsonc",
    "copyright:check": "tsx scripts/copyright-manager.ts --mode=check --include=src/**/*.ts,scripts/**/*.ts --exclude=**/node_modules/**,coverage/**,dist/**,tools/**",
    "copyright:fix": "tsx scripts/copyright-manager.ts --mode=fix --include=src/**/*.ts,scripts/**/*.ts --exclude=**/node_modules/**,coverage/**,dist/**,tools/**"
  },
